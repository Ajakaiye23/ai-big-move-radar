# Copy to ".env" and fill in. These are read from the environment by src/data/sources.py.
# Prices come from yfinance and need NO key. These keys unlock real TEXT/sentiment.

# Reddit (free): https://www.reddit.com/prefs/apps -> create app -> type "script"
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=ai-stock-sentiment/0.1

# Finnhub (free, 60 req/min): https://finnhub.io/register -> copy API key
FINNHUB_API_KEY=

# Optional: lift HuggingFace download rate limits for FinBERT weights
# HF_TOKEN=

# --- data window overrides (optional; otherwise config.yaml is used) ---
# DATA_MODE=live          # offline | auto | live
# DATA_START=2021-01-01
# DATA_END=today          # "today" => pull right up to the latest session
